{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-config.js",
      ".github/**",
      ".git/**",
      "**/.*"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{ "key": "Cache-Control", "value": "max-age=3600" }]
      }
    ]
  }
}
